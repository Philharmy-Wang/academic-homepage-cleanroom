---
import type { Language } from '../data/types';
import citations from '../data/generated/citations.json';
import { profile } from '../data/profile';
import ExternalLink from './ExternalLink.astro';
import Icon from './Icon.astro';

interface Props { lang: Language; }
const { lang } = Astro.props;
const counts = Object.entries(citations.aggregate.countsByYear as Record<string, number>)
  .filter(([year, count]) => /^\d{4}$/.test(year) && count >= 0)
  .sort(([left], [right]) => left.localeCompare(right))
  .slice(-7);
const workCount = Object.keys(citations.works).length;
const available = counts.length > 0;
const updated = citations.updatedAt
  ? new Intl.DateTimeFormat(lang === 'en' ? 'en-GB' : 'zh-CN', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' }).format(new Date(citations.updatedAt))
  : null;
const width = 680;
const height = 230;
const inset = { top: 28, right: 24, bottom: 38, left: 42 };
const maximum = Math.max(...counts.map(([, count]) => count), 1);
const chartPoints = counts.map(([year, count], index) => ({
  year,
  count,
  x: counts.length === 1 ? width / 2 : inset.left + (index / (counts.length - 1)) * (width - inset.left - inset.right),
  y: inset.top + (1 - count / maximum) * (height - inset.top - inset.bottom),
}));
const linePath = chartPoints.map((point, index) => `${index === 0 ? 'M' : 'L'} ${point.x.toFixed(1)} ${point.y.toFixed(1)}`).join(' ');
const areaPath = chartPoints.length
  ? `${linePath} L ${chartPoints.at(-1)!.x.toFixed(1)} ${height - inset.bottom} L ${chartPoints[0]!.x.toFixed(1)} ${height - inset.bottom} Z`
  : '';
const gridLines = [0, 0.25, 0.5, 0.75, 1].map((ratio) => ({
  y: inset.top + ratio * (height - inset.top - inset.bottom),
  value: Math.round(maximum * (1 - ratio)),
}));
const copy = lang === 'en' ? {
  title: 'OpenAlex citation trajectory', eyebrow: 'Independent cross-check', works: 'OpenAlex matched works',
  summary: `OpenAlex currently links ${workCount} works. The line shows its citations-received-by-year series.`,
  fallback: 'A verified citation trend is not available yet. Publication links remain available below.',
  footnote: 'OpenAlex annual metadata is shown only as an independent trend; Google Scholar profile statistics above come from the July 2026 manual snapshot.',
  updated: 'Snapshot', scholar: 'Google Scholar profile',
} : {
  title: 'OpenAlex 引用趋势', eyebrow: '独立交叉核验', works: 'OpenAlex 匹配论文',
  summary: `OpenAlex 当前匹配 ${workCount} 篇论文，折线仅展示其各年度引用数据。`,
  fallback: '当前暂无可核验的引用趋势数据，论文链接仍可在下方访问。',
  footnote: 'OpenAlex 年度数据仅作独立趋势参考；上方 Google Scholar 统计来自 2026-07 人工快照。',
  updated: '数据快照', scholar: 'Google Scholar 主页',
};
---

<section class="citation-trend" aria-labelledby={`citation-title-${lang}`}>
  <div class="citation-trend-heading">
    <div class="citation-heading-copy">
      <span class="section-icon" aria-hidden="true"><Icon name="citation" /></span>
      <div><p class="eyebrow">{copy.eyebrow}</p><h2 id={`citation-title-${lang}`}>{copy.title}</h2></div>
    </div>
    <ExternalLink class="citation-scholar-link" href={profile.scholar}><Icon name="scholar" />{copy.scholar}</ExternalLink>
  </div>
  <div class="citation-overview"><div><strong>{workCount}</strong><span>{copy.works}</span></div></div>
  {available ? (
    <div class="citation-chart-wrap">
      <p class="sr-only" id={`citation-summary-${lang}`}>{copy.summary}</p>
      <svg class="citation-chart" viewBox={`0 0 ${width} ${height}`} role="img" aria-describedby={`citation-summary-${lang}`}>
        {gridLines.map((line) => (
          <g class="chart-gridline">
            <line x1={inset.left} x2={width - inset.right} y1={line.y} y2={line.y} />
            <text x={inset.left - 9} y={line.y + 4} text-anchor="end">{line.value}</text>
          </g>
        ))}
        <path class="chart-area" d={areaPath} />
        <path class="chart-line" d={linePath} />
        {chartPoints.map((point) => (
          <g class="chart-point">
            <circle cx={point.x} cy={point.y} r="4.5" />
            <text class="chart-value" x={point.x} y={point.y - 11} text-anchor="middle">{point.count}</text>
            <text class="chart-year" x={point.x} y={height - 13} text-anchor="middle">{point.year}</text>
          </g>
        ))}
      </svg>
    </div>
  ) : <p class="citation-fallback">{copy.fallback}</p>}
  <div class="citation-caption"><p>{copy.footnote}</p>{updated && <p>{copy.updated}: {updated} UTC</p>}</div>
</section>
