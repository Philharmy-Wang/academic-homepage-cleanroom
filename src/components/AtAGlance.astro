---
import type { Language } from '../data/types';
import { publicationStats } from '../data/publicationStats';

interface Props { lang: Language; }
const { lang } = Astro.props;
const facts = lang === 'en' ? [
  { value: publicationStats.scholarItemCount, label: 'Google Scholar items' },
  { value: publicationStats.soleFirstAuthorCount, label: 'Sole-first-author papers' },
  { value: `${publicationStats.casZone1Count} / ${publicationStats.casTopCount}`, label: 'CAS Zone 1 / TOP journals' },
  { value: publicationStats.scholarTotalCitations, label: 'Google Scholar citations' },
] : [
  { value: publicationStats.scholarItemCount, label: 'Google Scholar 收录' },
  { value: publicationStats.soleFirstAuthorCount, label: '唯一第一作者论文' },
  { value: `${publicationStats.casZone1Count} / ${publicationStats.casTopCount}`, label: '中科院一区 / TOP 期刊' },
  { value: publicationStats.scholarTotalCitations, label: 'Google Scholar 总引用' },
];
---

<aside class="at-a-glance" aria-label={lang === 'en' ? 'At a glance' : '学术概览'} data-scholar-snapshot={publicationStats.scholarSnapshot}>
  <p class="eyebrow">{lang === 'en' ? 'At a glance' : '学术概览'}</p>
  <div class="fact-grid">
    {facts.map((fact) => <div class="fact-item"><strong>{fact.value}</strong><span>{fact.label}</span></div>)}
  </div>
</aside>
