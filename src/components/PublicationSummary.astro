---
import type { Language } from '../data/types';
import { publicationStats } from '../data/publicationStats';

interface Props { lang: Language; compact?: boolean; extended?: boolean; }
const { lang, compact = false, extended = false } = Astro.props;
const homeStats = lang === 'en' ? [
  { value: publicationStats.scholarItemCount, label: 'Google Scholar items' },
  { value: publicationStats.soleFirstAuthorCount, label: 'Sole first author' },
  { value: `${publicationStats.casZone1Count} / ${publicationStats.casTopCount}`, label: 'CAS Zone 1 / TOP journals' },
  { value: publicationStats.scholarTotalCitations, label: 'Google Scholar citations', accent: true },
] : [
  { value: publicationStats.scholarItemCount, label: 'Google Scholar 收录' },
  { value: publicationStats.soleFirstAuthorCount, label: '唯一第一作者' },
  { value: `${publicationStats.casZone1Count} / ${publicationStats.casTopCount}`, label: '中科院一区 / TOP 期刊' },
  { value: publicationStats.scholarTotalCitations, label: 'Google Scholar 总引用', accent: true },
];
const detailedStats = lang === 'en' ? [
  { value: publicationStats.verifiedPublicationCount, label: 'Verified publications' },
  { value: publicationStats.scholarItemCount, label: 'Scholar items' },
  { value: publicationStats.soleFirstAuthorCount, label: 'Sole first author' },
  { value: publicationStats.casZone1Count, label: 'CAS Zone 1' },
  { value: publicationStats.casTopCount, label: 'CAS TOP journals' },
  { value: publicationStats.scholarTotalCitations, label: 'Scholar citations', accent: true },
  { value: publicationStats.scholarHIndex, label: 'h-index' },
  { value: publicationStats.scholarI10Index, label: 'i10-index' },
] : [
  { value: publicationStats.verifiedPublicationCount, label: '已核验正式论文' },
  { value: publicationStats.scholarItemCount, label: 'Scholar 收录条目' },
  { value: publicationStats.soleFirstAuthorCount, label: '唯一第一作者' },
  { value: publicationStats.casZone1Count, label: '中科院一区' },
  { value: publicationStats.casTopCount, label: 'TOP 期刊' },
  { value: publicationStats.scholarTotalCitations, label: 'Scholar 总引用', accent: true },
  { value: publicationStats.scholarHIndex, label: 'h-index' },
  { value: publicationStats.scholarI10Index, label: 'i10-index' },
];
const stats = extended ? detailedStats : homeStats;
---

<div class:list={['publication-summary', { compact, extended }]} aria-label={lang === 'en' ? 'Publication summary' : '论文概览'} data-scholar-snapshot={publicationStats.scholarSnapshot}>
  {stats.map((stat) => (
    <div class:list={['summary-stat', { accent: stat.accent }]}>
      <strong>{stat.value}</strong>
      <span>{stat.label}</span>
    </div>
  ))}
</div>
