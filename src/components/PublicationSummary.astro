---
import type { Language } from '../data/types';
import { publications } from '../data/publications';
import citations from '../data/generated/citations.json';

interface Props { lang: Language; compact?: boolean; }
const { lang, compact = false } = Astro.props;
const soleFirstAuthorCount = publications.filter((item) => item.role.en === 'Sole First Author').length;
const topCount = publications.filter((item) => item.metrics.some((metric) => metric.label === 'CAS' && metric.value.includes('TOP') && (metric.verifiedYear || metric.verifiedAt))).length;
const stats = lang === 'en' ? [
  { value: publications.length, label: 'Publications' },
  { value: soleFirstAuthorCount, label: 'Sole first author' },
  { value: topCount, label: 'CAS Zone 1 · TOP' },
  { value: citations.aggregate.totalCitations, label: 'OpenAlex citations', accent: true },
] : [
  { value: publications.length, label: '论文' },
  { value: soleFirstAuthorCount, label: '唯一第一作者' },
  { value: topCount, label: '中科院一区 · TOP' },
  { value: citations.aggregate.totalCitations, label: 'OpenAlex 总引用', accent: true },
];
---

<div class:list={['publication-summary', { compact }]} aria-label={lang === 'en' ? 'Publication summary' : '论文概览'}>
  {stats.map((stat) => (
    <div class:list={['summary-stat', { accent: stat.accent }]}>
      <strong>{stat.value}</strong>
      <span>{stat.label}</span>
    </div>
  ))}
</div>
