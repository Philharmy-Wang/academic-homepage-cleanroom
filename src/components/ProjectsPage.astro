---
import type { Language } from '../data/types';
import { projects } from '../data/projects';
import ContentLayout from '../layouts/ContentLayout.astro';
import ProjectCard from './ProjectCard.astro';
interface Props { lang: Language; }
const { lang } = Astro.props;
const groupNames = {
  current: { en: 'Current Primate Vision Research', zh: '当前灵长类视觉研究' },
  funded: { en: 'Funded Projects and Talent Programs', zh: '资助项目与人才计划' },
  previous: { en: 'Previous Wildfire and Multimodal Vision Projects', zh: '前期森林火灾与多模态视觉项目' },
  participated: { en: 'Participated Projects', zh: '参与项目' },
};
const groups = Object.keys(groupNames) as Array<keyof typeof groupNames>;
const copy = lang === 'en' ? {
  title: 'Projects', description: 'Public research projects, grants, and talent programs led by or involving Guanbo Wang.',
  intro: 'Only public project information is presented. Funding amounts, internal identifiers, private paths, and unreleased operational details are intentionally excluded.', eyebrow: 'Research portfolio',
} : {
  title: '科研项目', description: '王冠博主持或参与的公开科研项目、资助与人才计划。',
  intro: '本页仅展示公开项目信息，不呈现经费金额、内部编号、私有路径或未发布的实施细节。', eyebrow: '项目概览',
};
---
<ContentLayout lang={lang} route="/projects/" title={copy.title} description={copy.description} intro={copy.intro} eyebrow={copy.eyebrow}>
  {groups.map((group) => (
    <section class="content-section" aria-labelledby={`project-${group}`}>
      <h2 id={`project-${group}`}>{groupNames[group][lang]}</h2>
      <div class="project-list">
        {projects.filter((project) => project.group === group).map((project) => <ProjectCard project={project} lang={lang} />)}
      </div>
    </section>
  ))}
</ContentLayout>
