---
import type { Language, Publication } from '../data/types';
import citations from '../data/generated/citations.json';
import { withBase } from '../utils/paths';
import ExternalLink from './ExternalLink.astro';
import Icon from './Icon.astro';
import MetricBadge from './MetricBadge.astro';

interface Props {
  publication: Publication;
  lang: Language;
  compact?: boolean;
  cv?: boolean;
  number?: number | undefined;
  showFigure?: boolean;
}
interface CitationEntry { totalCitations: number; source: string; }
const { publication, lang, compact = false, cv = false, number, showFigure = !cv } = Astro.props;
const authorLabel = publication.authors.map((author) => ({
  ...author,
  display: author.self ? 'Guanbo Wang' : (lang === 'zh' && author.nameZh ? author.nameZh : author.name),
}));
const bibliographicParts = [
  publication.volume && publication.issue ? `${publication.volume}(${publication.issue})` : publication.volume,
  publication.pages ?? publication.articleNumber,
].filter(Boolean);
const scholarUrl = publication.scholarUrl ?? `https://scholar.google.com/scholar?q=${encodeURIComponent(publication.title)}`;
const citationEntry = (citations.works as Record<string, CitationEntry>)[publication.id];
const citationDate = citations.updatedAt
  ? new Intl.DateTimeFormat(lang === 'en' ? 'en-GB' : 'zh-CN', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' }).format(new Date(citations.updatedAt))
  : null;
const verifiedMetrics = publication.metrics.filter((metric) => metric.verifiedYear || metric.verifiedAt);
const structuredLinks = [
  publication.doi && { label: 'DOI', url: `https://doi.org/${publication.doi}` },
  publication.publisherUrl && { label: 'Publisher', url: publication.publisherUrl },
  publication.pdfUrl && { label: 'PDF', url: publication.pdfUrl },
  publication.codeUrl && { label: 'Code', url: publication.codeUrl },
  publication.datasetUrl && { label: 'Dataset', url: publication.datasetUrl },
  publication.projectUrl && { label: 'Project', url: publication.projectUrl },
  ...publication.links,
].filter((link): link is { label: string; url: string } => Boolean(link));
const directLinks = [...new Map(structuredLinks.map((link) => [link.url, link])).values()];
const hasFigure = Boolean(showFigure && publication.figure);
const metricEdition = (metric: Publication['metrics'][number]) => metric.verifiedYear
  ? `${metric.label} · ${metric.verifiedYear}`
  : `${metric.label} · ${lang === 'en' ? 'snapshot' : '快照'} ${metric.verifiedAt}`;
---

<article class:list={['publication-card', { compact, cv, 'has-figure': hasFigure }]} id={publication.id}>
  <div class="publication-index" aria-label={number ? (lang === 'en' ? `Publication ${number}` : `论文 ${number}`) : undefined}>
    {number && <span class="publication-number">{String(number).padStart(2, '0')}</span>}
    <span class="publication-year">{publication.year}</span>
  </div>
  <div class="publication-content">
    <div class="publication-body">
      <div class="publication-kicker"><span>{publication.role[lang]}</span><span>{publication.venue}</span></div>
      <h3>{lang === 'zh' && publication.titleZh ? publication.titleZh : publication.title}</h3>
      <p class="authors">
        {authorLabel.map((author, index) => (
          <><span class:list={{ 'self-author': author.self }} lang={author.self ? 'en' : (lang === 'zh' && author.nameZh ? 'zh-CN' : undefined)}>{author.display}{author.corresponding ? <sup title={lang === 'en' ? 'Corresponding author' : '通讯作者'}>*</sup> : ''}</span>{index < authorLabel.length - 1 ? ', ' : ''}</>
        ))}
      </p>
      <p class="venue"><em>{publication.venue}</em>, {publication.year}{bibliographicParts.length ? `, ${bibliographicParts.join(', ')}` : ''}.</p>
      {verifiedMetrics.length > 0 && (
        <div class="metric-row" aria-label={lang === 'en' ? 'Audited journal indicators' : '已核验期刊指标'}>
          {verifiedMetrics.map((metric) => <MetricBadge label={metricEdition(metric)} value={metric.value} source={metric.source} />)}
        </div>
      )}
      <div class="publication-meta-row">
        {citationEntry && (
          <span class="citation-pill" title={citationDate ? `${lang === 'en' ? 'OpenAlex snapshot' : 'OpenAlex 快照'}: ${citationDate} UTC` : undefined}>
            <Icon name="citation" />
            <strong>{citationEntry.totalCitations}</strong> {lang === 'en' ? 'citations' : '次引用'}
          </span>
        )}
        <div class="publication-links">
          {directLinks.map((link) => <ExternalLink href={link.url}>{link.label}</ExternalLink>)}
          <ExternalLink href={scholarUrl}>Google Scholar</ExternalLink>
        </div>
      </div>
    </div>
    {hasFigure && (
      <figure class="publication-figure">
        <img src={withBase(publication.figure!.src)} alt={publication.figure!.alt[lang]} width={publication.figure!.width} height={publication.figure!.height} loading="eager" />
      </figure>
    )}
  </div>
</article>
