---
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';
import type { Language, Publication } from '../data/types';
import { getPublicationRole, getScholarCitationCount, publicationStats } from '../data/publicationStats';
import { withBase } from '../utils/paths';
import ExternalLink from './ExternalLink.astro';
import Icon from './Icon.astro';
import MetricBadge from './MetricBadge.astro';

interface Props {
  publication: Publication;
  lang: Language;
  compact?: boolean;
  cv?: boolean;
  number?: number | undefined;
  showFigure?: boolean;
}

const { publication, lang, compact = false, cv = false, number, showFigure = !cv } = Astro.props;
const role = getPublicationRole(publication);
const authorLabel = publication.authors.map((author) => ({
  ...author,
  display: author.self ? 'Guanbo Wang' : (lang === 'zh' && author.nameZh ? author.nameZh : author.name),
}));
const bibliographicParts = [
  publication.volume && publication.issue ? `${publication.volume}(${publication.issue})` : publication.volume,
  publication.pages ?? publication.articleNumber,
].filter(Boolean);
const scholarUrl = publication.scholarUrl ?? `https://scholar.google.com/scholar?q=${encodeURIComponent(publication.title)}`;
const scholarCitations = getScholarCitationCount(publication.id);
const structuredLinks = [
  publication.doi && { label: 'DOI', url: `https://doi.org/${publication.doi}` },
  publication.publisherUrl && { label: 'Publisher', url: publication.publisherUrl },
  publication.pdfUrl && { label: 'PDF', url: publication.pdfUrl },
  publication.codeUrl && { label: 'Code', url: publication.codeUrl },
  publication.datasetUrl && { label: 'Dataset', url: publication.datasetUrl },
  publication.projectUrl && { label: 'Project', url: publication.projectUrl },
  ...publication.links,
].filter((link): link is { label: string; url: string } => Boolean(link));
const directLinks = [...new Map(structuredLinks.map((link) => [link.url, link])).values()];
const hasFigure = Boolean(showFigure && publication.figure);
const preferredFigureAvailable = Boolean(publication.figure?.preferredSrc && existsSync(resolve('public', publication.figure.preferredSrc.replace(/^\//, ''))));
const figureSrc = publication.figure
  ? (preferredFigureAvailable ? publication.figure.preferredSrc! : publication.figure.src)
  : null;
const metrics = publication.metrics;
const casZoneLabels = lang === 'en'
  ? { 1: 'Zone 1', 2: 'Zone 2', 3: 'Zone 3', 4: 'Zone 4' }
  : { 1: '一区', 2: '二区', 3: '三区', 4: '四区' };
const metricBadges = [
  metrics.casZone && {
    label: lang === 'en' ? 'CAS' : '中科院',
    value: `${casZoneLabels[metrics.casZone]}${metrics.casTop ? ' TOP' : ''}`,
    source: [metrics.casEdition, metrics.casSourceUrl].filter(Boolean).join(' · '),
  },
  metrics.jcrQuartile && { label: 'JCR', value: metrics.jcrQuartile, source: [metrics.jcrEdition, metrics.jcrSourceUrl].filter(Boolean).join(' · ') },
  metrics.jif !== null && { label: 'IF', value: String(metrics.jif), source: [metrics.jifYear, metrics.jcrEdition, metrics.jcrSourceUrl].filter(Boolean).join(' · ') },
  metrics.fiveYearJif !== null && { label: '5-Year IF', value: String(metrics.fiveYearJif), source: [metrics.jifYear, metrics.jcrEdition, metrics.jcrSourceUrl].filter(Boolean).join(' · ') },
].filter((item): item is { label: string; value: string; source: string } => Boolean(item));
---

<article class:list={['publication-card', { compact, cv, 'has-figure': hasFigure }]} id={publication.id}>
  <div class="publication-index" aria-label={number ? (lang === 'en' ? `Publication ${number}` : `论文 ${number}`) : undefined}>
    {number && <span class="publication-number">{String(number).padStart(2, '0')}</span>}
    <span class="publication-year">{publication.year}</span>
  </div>
  <div class="publication-content">
    <div class="publication-body">
      <div class="publication-kicker"><span>{role[lang]}</span><span>{publication.venue}</span></div>
      <h3>{lang === 'zh' && publication.titleZh ? publication.titleZh : publication.title}</h3>
      <p class="authors">
        {authorLabel.map((author, index) => (
          <><span class:list={{ 'self-author': author.self }} lang={author.self ? 'en' : (lang === 'zh' && author.nameZh ? 'zh-CN' : undefined)}>{author.display}{author.corresponding ? <sup title={lang === 'en' ? 'Corresponding author' : '通讯作者'}>*</sup> : ''}</span>{index < authorLabel.length - 1 ? ', ' : ''}</>
        ))}
      </p>
      <p class="venue"><em>{publication.venue}</em>, {publication.year}{bibliographicParts.length ? `, ${bibliographicParts.join(', ')}` : ''}.</p>
      {metricBadges.length > 0 && (
        <div class="metric-row" aria-label={lang === 'en' ? 'Audited journal indicators' : '已核验期刊指标'}>
          {metricBadges.map((metric) => <MetricBadge label={metric.label} value={metric.value} source={metric.source} />)}
        </div>
      )}
      <div class="publication-meta-row">
        {scholarCitations !== null && (
          <span class="citation-pill" title={`Google Scholar · ${publicationStats.scholarSnapshot}`}>
            <Icon name="citation" />
            <strong>{scholarCitations}</strong> {lang === 'en' ? 'Google Scholar citations' : '次 Google Scholar 引用'}
          </span>
        )}
        <div class="publication-links">
          {directLinks.map((link) => <ExternalLink href={link.url}>{link.label}</ExternalLink>)}
          <ExternalLink href={scholarUrl}>Google Scholar</ExternalLink>
        </div>
      </div>
    </div>
    {hasFigure && figureSrc && (
      <figure class="publication-figure" data-image-source={preferredFigureAvailable ? 'custom' : 'fallback'}>
        <a href={withBase(figureSrc)} target="_blank" rel="noopener noreferrer" aria-label={lang === 'en' ? 'Open publication figure' : '查看论文主图'}>
          <img src={withBase(figureSrc)} alt={publication.figure!.alt[lang]} width={publication.figure!.width} height={publication.figure!.height} loading="eager" />
        </a>
      </figure>
    )}
  </div>
</article>
