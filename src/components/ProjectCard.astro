---
import type { Language, Project } from '../data/types';
import Icon from './Icon.astro';

interface Props { project: Project; lang: Language; index?: number; }
const { project, lang, index } = Astro.props;
const period = typeof project.period === 'string' ? project.period : project.period?.[lang];
const statusClass = project.status?.en === 'Ongoing' ? 'ongoing' : 'completed';
---

<article class="project-card" id={project.id}>
  <span class="project-marker" aria-hidden="true"><Icon name="project" /></span>
  <div class="project-card-content">
    <div class="project-card-kicker">
      {index && <span>{String(index).padStart(2, '0')}</span>}
      <span>{project.title[lang]}</span>
    </div>
    <h3>{project.project[lang]}</h3>
    {project.organization && <p class="organization">{project.organization[lang]}</p>}
    <div class="project-meta">
      <span class="project-role">{project.role[lang]}</span>
      {period && <span>{period}</span>}
      {project.status && <span class:list={['project-status', statusClass]}>{project.status[lang]}</span>}
    </div>
  </div>
</article>
