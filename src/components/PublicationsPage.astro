---
import type { Language, Publication } from '../data/types';
import { publications, selectedPublications } from '../data/publications';
import ContentLayout from '../layouts/ContentLayout.astro';
import CitationTrend from './CitationTrend.astro';
import Icon from './Icon.astro';
import PublicationCard from './PublicationCard.astro';

interface Props { lang: Language; }
const { lang } = Astro.props;
const groups: Array<{ key: string; title: { en: string; zh: string }; items: Publication[] }> = [
  { key: 'selected', title: { en: 'Selected Publications', zh: '代表性论文' }, items: selectedPublications },
  { key: 'first', title: { en: 'First-author Publications', zh: '第一作者论文' }, items: publications.filter((item) => item.group === 'First-author Publications' && !item.selected) },
  { key: 'coauthored', title: { en: 'Co-authored Publications', zh: '合作论文' }, items: publications.filter((item) => item.group === 'Co-authored Publications') },
  { key: 'chinese', title: { en: 'Chinese Publications', zh: '中文论文' }, items: publications.filter((item) => item.group === 'Chinese Publications') },
];
const copy = lang === 'en' ? {
  title: 'Publications', description: 'Selected and complete publication records for Guanbo Wang, with authorship, contributions, public links, and citation snapshots.',
  intro: 'Research outputs across remote sensing, multimodal vision, efficient detection, image fusion, tracking, and applied visual intelligence.',
  eyebrow: 'Research outputs', star: '* Corresponding author.',
} : {
  title: '论文', description: 'Guanbo Wang 的代表性及完整论文记录，包含作者、本人贡献、公开链接与引用快照。',
  intro: '研究成果涵盖遥感、多模态视觉、高效检测、图像融合、目标跟踪与视觉智能应用。',
  eyebrow: '研究成果', star: '* 通讯作者。',
};
---

<ContentLayout lang={lang} route="/publications/" title={copy.title} description={copy.description} intro={copy.intro} eyebrow={copy.eyebrow}>
  {groups.map((group) => (
    <>
      <section class="content-section publication-group" aria-labelledby={`group-${group.key}`} data-publication-group={group.key}>
        <h2 id={`group-${group.key}`}><Icon name="paper" />{group.title[lang]}</h2>
        <div class="publication-list">
          {group.items.map((publication) => <PublicationCard publication={publication} lang={lang} />)}
        </div>
      </section>
      {group.key === 'selected' && <CitationTrend lang={lang} />}
    </>
  ))}
  <section class="content-section publication-notes" aria-label={lang === 'en' ? 'Publication notes' : '论文说明'}>
    <p class="metric-footnote">{copy.star}</p>
  </section>
</ContentLayout>
