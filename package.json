{
  "name": "academic-homepage-cleanroom",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "validate:data": "node --import tsx scripts/validate-data.mjs",
    "check:links": "node scripts/check-internal-links.mjs",
    "privacy:audit": "node scripts/privacy-audit.mjs",
    "safety:remote": "node scripts/assert-safe-remote.mjs",
    "test:visual": "playwright test --project=desktop",
    "test:responsive": "playwright test",
    "report": "node scripts/generate-report.mjs",
    "audit:all": "npm run check && npm run validate:data && npm run build && npm run check:links && npm run privacy:audit && npm run safety:remote && npm run test:responsive && npm run report"
  },
  "dependencies": {
    "astro": "^7.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
